# ===========================================
# Sistema Repartos - Variables de entorno
# Copiá este archivo a .env y completá los valores
# ===========================================

# --- General ---
APP_ENV=production
APP_DEBUG=false

# --- MySQL ---
MYSQL_ROOT_PASSWORD=cambiar_password_seguro
MYSQL_DATABASE=sistema_repartos
MYSQL_USER=repartos_user
MYSQL_PASSWORD=cambiar_password_seguro

# --- Backend ---
DB_HOST=mysql
DB_NAME=sistema_repartos
DB_USER=repartos_user
DB_PASS=cambiar_password_seguro
JWT_SECRET=cambiar_jwt_secret_largo_y_aleatorio
CORS_ORIGIN=http://localhost

# --- Frontend (build) ---
# Dejar vacío en producción para usar el mismo dominio vía Nginx
VITE_API_URL=

# --- Puertos (producción) ---
HTTP_PORT=80
